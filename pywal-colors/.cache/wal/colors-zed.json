{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#162f3390",
                "editor.background": "#162f3390",
                "editor.foreground": "#c4cbcc",
                "text": "#c4cbcc",
                "text.muted": "#c4cbcc70",
                "text.ignored": "#c4cbcc40",
                "text.placeholder": "#c4cbcc50",
                "ignored": "#c4cbcc30",
                "element.hover": "#c4cbcc30",
                "ghost_element.hover": "#4A788830",
                "ghost_element.selected": "#4A788830",
                "ghost_element.active": "#4A788860",
                "border": "#162f33",
                "editor.highlighted_line.background": "#4A788810",
                "editor.active_line.background": "#4A788810",
                "panel.background": "#162f3390",
                "title_bar.background": "#162f3390",
                "title_bar.inactive_background": "#162f3390",
                "status_bar.background": "#162f3390",
                "drop_target.background": "#162f3390",
                "elevated_surface.background": "#162f33",
                "toolbar.background": "#162f3390",
                "tab_bar.background": "#162f3390",
                "tab.inactive_background": "#162f3390",
                "tab.active_background": "#4A788830",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#162f33",
                "scrollbar.thumb.background": "#4A7888",
                "editor.gutter.background": "#162f3390",
                "terminal.background": "#162f3310",
                "terminal.foreground": "#c4cbcc",
                "terminal.dim_foreground": "#c4cbcc",
                "terminal.bright_foreground": "#c4cbcc",
                "terminal.ansi.black": "#162f33",
                "terminal.ansi.red": "#4A7888",
                "terminal.ansi.green": "#5A9298",
                "terminal.ansi.yellow": "#4C96AD",
                "terminal.ansi.blue": "#76CDDC",
                "terminal.ansi.magenta": "#78C7E2",
                "terminal.ansi.cyan": "#9BAE9F",
                "terminal.ansi.white": "#c4cbcc",
                "terminal.ansi.bright_black": "#65787b",
                "terminal.ansi.bright_red": "#4A7888",
                "terminal.ansi.bright_green": "#5A9298",
                "terminal.ansi.bright_yellow": "#4C96AD",
                "terminal.ansi.bright_blue": "#76CDDC",
                "terminal.ansi.bright_magenta": "#78C7E2",
                "terminal.ansi.bright_cyan": "#9BAE9F",
                "terminal.ansi.bright_white": "#c4cbcc",
                "modified": "#4A7888",
                "syntax": {
                    "attribute": {
                        "color": "#4A7888"
                    },
                    "boolean": {
                      "color": "#5A9298"
                    },
                    "comment": {
                      "color": "#65787b"
                    },
                    "comment.doc": {
                      "color": "#65787b"
                    },
                    "constant": {
                      "color": "#5A9298"
                    },
                    "function": {
                      "color": "#9BAE9F"
                    },
                    "keyword": {
                      "color": "#76CDDC"
                    },
                    "number": {
                      "color": "#78C7E2"
                    },
                    "operator": {
                      "color": "#76CDDC"
                    },
                    "string": {
                      "color": "#4A7888"
                    },
                    "variable": {
                      "color": "#5A9298"
                    }
                },
                "players": [
                  {
                    "cursor": "#4A7888",
                    "background": "#162f33",
                    "selection": "#4A788830"
                  }
                ]
            }
        }
    ]
}
