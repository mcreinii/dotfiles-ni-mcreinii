{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#10101090",
                "editor.background": "#10101090",
                "editor.foreground": "#c3c3c3",
                "text": "#c3c3c3",
                "text.muted": "#c3c3c370",
                "text.ignored": "#c3c3c340",
                "text.placeholder": "#c3c3c350",
                "ignored": "#c3c3c330",
                "element.hover": "#c3c3c330",
                "ghost_element.hover": "#586DAE30",
                "ghost_element.selected": "#586DAE30",
                "ghost_element.active": "#586DAE60",
                "border": "#101010",
                "editor.highlighted_line.background": "#586DAE10",
                "editor.active_line.background": "#586DAE10",
                "panel.background": "#10101090",
                "title_bar.background": "#10101090",
                "title_bar.inactive_background": "#10101090",
                "status_bar.background": "#10101090",
                "drop_target.background": "#10101090",
                "elevated_surface.background": "#101010",
                "toolbar.background": "#10101090",
                "tab_bar.background": "#10101090",
                "tab.inactive_background": "#10101090",
                "tab.active_background": "#586DAE30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#101010",
                "scrollbar.thumb.background": "#586DAE",
                "editor.gutter.background": "#10101090",
                "terminal.background": "#10101010",
                "terminal.foreground": "#c3c3c3",
                "terminal.dim_foreground": "#c3c3c3",
                "terminal.bright_foreground": "#c3c3c3",
                "terminal.ansi.black": "#101010",
                "terminal.ansi.red": "#586DAE",
                "terminal.ansi.green": "#647AB6",
                "terminal.ansi.yellow": "#6376D1",
                "terminal.ansi.blue": "#6981BC",
                "terminal.ansi.magenta": "#6E88CE",
                "terminal.ansi.cyan": "#7891E2",
                "terminal.ansi.white": "#c3c3c3",
                "terminal.ansi.bright_black": "#6c5959",
                "terminal.ansi.bright_red": "#586DAE",
                "terminal.ansi.bright_green": "#647AB6",
                "terminal.ansi.bright_yellow": "#6376D1",
                "terminal.ansi.bright_blue": "#6981BC",
                "terminal.ansi.bright_magenta": "#6E88CE",
                "terminal.ansi.bright_cyan": "#7891E2",
                "terminal.ansi.bright_white": "#c3c3c3",
                "modified": "#586DAE",
                "syntax": {
                    "attribute": {
                        "color": "#586DAE"
                    },
                    "boolean": {
                      "color": "#647AB6"
                    },
                    "comment": {
                      "color": "#6c5959"
                    },
                    "comment.doc": {
                      "color": "#6c5959"
                    },
                    "constant": {
                      "color": "#647AB6"
                    },
                    "function": {
                      "color": "#7891E2"
                    },
                    "keyword": {
                      "color": "#6981BC"
                    },
                    "number": {
                      "color": "#6E88CE"
                    },
                    "operator": {
                      "color": "#6981BC"
                    },
                    "string": {
                      "color": "#586DAE"
                    },
                    "variable": {
                      "color": "#647AB6"
                    }
                },
                "players": [
                  {
                    "cursor": "#586DAE",
                    "background": "#101010",
                    "selection": "#586DAE30"
                  }
                ]
            }
        }
    ]
}
