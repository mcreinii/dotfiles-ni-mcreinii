{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0b0b1a90",
                "editor.background": "#0b0b1a90",
                "editor.foreground": "#c2c2c5",
                "text": "#c2c2c5",
                "text.muted": "#c2c2c570",
                "text.ignored": "#c2c2c540",
                "text.placeholder": "#c2c2c550",
                "ignored": "#c2c2c530",
                "element.hover": "#c2c2c530",
                "ghost_element.hover": "#686D9430",
                "ghost_element.selected": "#686D9430",
                "ghost_element.active": "#686D9460",
                "border": "#0b0b1a",
                "editor.highlighted_line.background": "#686D9410",
                "editor.active_line.background": "#686D9410",
                "panel.background": "#0b0b1a90",
                "title_bar.background": "#0b0b1a90",
                "title_bar.inactive_background": "#0b0b1a90",
                "status_bar.background": "#0b0b1a90",
                "drop_target.background": "#0b0b1a90",
                "elevated_surface.background": "#0b0b1a",
                "toolbar.background": "#0b0b1a90",
                "tab_bar.background": "#0b0b1a90",
                "tab.inactive_background": "#0b0b1a90",
                "tab.active_background": "#686D9430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0b0b1a",
                "scrollbar.thumb.background": "#686D94",
                "editor.gutter.background": "#0b0b1a90",
                "terminal.background": "#0b0b1a10",
                "terminal.foreground": "#c2c2c5",
                "terminal.dim_foreground": "#c2c2c5",
                "terminal.bright_foreground": "#c2c2c5",
                "terminal.ansi.black": "#0b0b1a",
                "terminal.ansi.red": "#686D94",
                "terminal.ansi.green": "#686D95",
                "terminal.ansi.yellow": "#7D83B1",
                "terminal.ansi.blue": "#838AB9",
                "terminal.ansi.magenta": "#949BD1",
                "terminal.ansi.cyan": "#B4BDFD",
                "terminal.ansi.white": "#c2c2c5",
                "terminal.ansi.bright_black": "#5a5a6f",
                "terminal.ansi.bright_red": "#686D94",
                "terminal.ansi.bright_green": "#686D95",
                "terminal.ansi.bright_yellow": "#7D83B1",
                "terminal.ansi.bright_blue": "#838AB9",
                "terminal.ansi.bright_magenta": "#949BD1",
                "terminal.ansi.bright_cyan": "#B4BDFD",
                "terminal.ansi.bright_white": "#c2c2c5",
                "modified": "#686D94",
                "syntax": {
                    "attribute": {
                        "color": "#686D94"
                    },
                    "boolean": {
                      "color": "#686D95"
                    },
                    "comment": {
                      "color": "#5a5a6f"
                    },
                    "comment.doc": {
                      "color": "#5a5a6f"
                    },
                    "constant": {
                      "color": "#686D95"
                    },
                    "function": {
                      "color": "#B4BDFD"
                    },
                    "keyword": {
                      "color": "#838AB9"
                    },
                    "number": {
                      "color": "#949BD1"
                    },
                    "operator": {
                      "color": "#838AB9"
                    },
                    "string": {
                      "color": "#686D94"
                    },
                    "variable": {
                      "color": "#686D95"
                    }
                },
                "players": [
                  {
                    "cursor": "#686D94",
                    "background": "#0b0b1a",
                    "selection": "#686D9430"
                  }
                ]
            }
        }
    ]
}
