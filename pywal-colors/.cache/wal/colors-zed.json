{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#17090990",
                "editor.background": "#17090990",
                "editor.foreground": "#c5c1c1",
                "text": "#c5c1c1",
                "text.muted": "#c5c1c170",
                "text.ignored": "#c5c1c140",
                "text.placeholder": "#c5c1c150",
                "ignored": "#c5c1c130",
                "element.hover": "#c5c1c130",
                "ghost_element.hover": "#C1584630",
                "ghost_element.selected": "#C1584630",
                "ghost_element.active": "#C1584660",
                "border": "#170909",
                "editor.highlighted_line.background": "#C1584610",
                "editor.active_line.background": "#C1584610",
                "panel.background": "#17090990",
                "title_bar.background": "#17090990",
                "title_bar.inactive_background": "#17090990",
                "status_bar.background": "#17090990",
                "drop_target.background": "#17090990",
                "elevated_surface.background": "#170909",
                "toolbar.background": "#17090990",
                "tab_bar.background": "#17090990",
                "tab.inactive_background": "#17090990",
                "tab.active_background": "#C1584630",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#170909",
                "scrollbar.thumb.background": "#C15846",
                "editor.gutter.background": "#17090990",
                "terminal.background": "#17090910",
                "terminal.foreground": "#c5c1c1",
                "terminal.dim_foreground": "#c5c1c1",
                "terminal.bright_foreground": "#c5c1c1",
                "terminal.ansi.black": "#170909",
                "terminal.ansi.red": "#C15846",
                "terminal.ansi.green": "#BB8566",
                "terminal.ansi.yellow": "#DB9572",
                "terminal.ansi.blue": "#BA7784",
                "terminal.ansi.magenta": "#F0AD9D",
                "terminal.ansi.cyan": "#F1B191",
                "terminal.ansi.white": "#c5c1c1",
                "terminal.ansi.bright_black": "#6d5959",
                "terminal.ansi.bright_red": "#C15846",
                "terminal.ansi.bright_green": "#BB8566",
                "terminal.ansi.bright_yellow": "#DB9572",
                "terminal.ansi.bright_blue": "#BA7784",
                "terminal.ansi.bright_magenta": "#F0AD9D",
                "terminal.ansi.bright_cyan": "#F1B191",
                "terminal.ansi.bright_white": "#c5c1c1",
                "modified": "#C15846",
                "syntax": {
                    "attribute": {
                        "color": "#C15846"
                    },
                    "boolean": {
                      "color": "#BB8566"
                    },
                    "comment": {
                      "color": "#6d5959"
                    },
                    "comment.doc": {
                      "color": "#6d5959"
                    },
                    "constant": {
                      "color": "#BB8566"
                    },
                    "function": {
                      "color": "#F1B191"
                    },
                    "keyword": {
                      "color": "#BA7784"
                    },
                    "number": {
                      "color": "#F0AD9D"
                    },
                    "operator": {
                      "color": "#BA7784"
                    },
                    "string": {
                      "color": "#C15846"
                    },
                    "variable": {
                      "color": "#BB8566"
                    }
                },
                "players": [
                  {
                    "cursor": "#C15846",
                    "background": "#170909",
                    "selection": "#C1584630"
                  }
                ]
            }
        }
    ]
}
