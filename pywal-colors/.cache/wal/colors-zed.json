{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#140e2090",
                "editor.background": "#140e2090",
                "editor.foreground": "#c4c2c7",
                "text": "#c4c2c7",
                "text.muted": "#c4c2c770",
                "text.ignored": "#c4c2c740",
                "text.placeholder": "#c4c2c750",
                "ignored": "#c4c2c730",
                "element.hover": "#c4c2c730",
                "ghost_element.hover": "#837B6930",
                "ghost_element.selected": "#837B6930",
                "ghost_element.active": "#837B6960",
                "border": "#140e20",
                "editor.highlighted_line.background": "#837B6910",
                "editor.active_line.background": "#837B6910",
                "panel.background": "#140e2090",
                "title_bar.background": "#140e2090",
                "title_bar.inactive_background": "#140e2090",
                "status_bar.background": "#140e2090",
                "drop_target.background": "#140e2090",
                "elevated_surface.background": "#140e20",
                "toolbar.background": "#140e2090",
                "tab_bar.background": "#140e2090",
                "tab.inactive_background": "#140e2090",
                "tab.active_background": "#837B6930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#140e20",
                "scrollbar.thumb.background": "#837B69",
                "editor.gutter.background": "#140e2090",
                "terminal.background": "#140e2010",
                "terminal.foreground": "#c4c2c7",
                "terminal.dim_foreground": "#c4c2c7",
                "terminal.bright_foreground": "#c4c2c7",
                "terminal.ansi.black": "#140e20",
                "terminal.ansi.red": "#837B69",
                "terminal.ansi.green": "#768E65",
                "terminal.ansi.yellow": "#739765",
                "terminal.ansi.blue": "#8AA174",
                "terminal.ansi.magenta": "#8FC17E",
                "terminal.ansi.cyan": "#A4AF8F",
                "terminal.ansi.white": "#c4c2c7",
                "terminal.ansi.bright_black": "#645d72",
                "terminal.ansi.bright_red": "#837B69",
                "terminal.ansi.bright_green": "#768E65",
                "terminal.ansi.bright_yellow": "#739765",
                "terminal.ansi.bright_blue": "#8AA174",
                "terminal.ansi.bright_magenta": "#8FC17E",
                "terminal.ansi.bright_cyan": "#A4AF8F",
                "terminal.ansi.bright_white": "#c4c2c7",
                "modified": "#837B69",
                "syntax": {
                    "attribute": {
                        "color": "#837B69"
                    },
                    "boolean": {
                      "color": "#768E65"
                    },
                    "comment": {
                      "color": "#645d72"
                    },
                    "comment.doc": {
                      "color": "#645d72"
                    },
                    "constant": {
                      "color": "#768E65"
                    },
                    "function": {
                      "color": "#A4AF8F"
                    },
                    "keyword": {
                      "color": "#8AA174"
                    },
                    "number": {
                      "color": "#8FC17E"
                    },
                    "operator": {
                      "color": "#8AA174"
                    },
                    "string": {
                      "color": "#837B69"
                    },
                    "variable": {
                      "color": "#768E65"
                    }
                },
                "players": [
                  {
                    "cursor": "#837B69",
                    "background": "#140e20",
                    "selection": "#837B6930"
                  }
                ]
            }
        }
    ]
}
