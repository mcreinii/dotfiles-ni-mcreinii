{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d0d1f90",
                "editor.background": "#0d0d1f90",
                "editor.foreground": "#c2c2c7",
                "text": "#c2c2c7",
                "text.muted": "#c2c2c770",
                "text.ignored": "#c2c2c740",
                "text.placeholder": "#c2c2c750",
                "ignored": "#c2c2c730",
                "element.hover": "#c2c2c730",
                "ghost_element.hover": "#3D4E6430",
                "ghost_element.selected": "#3D4E6430",
                "ghost_element.active": "#3D4E6460",
                "border": "#0d0d1f",
                "editor.highlighted_line.background": "#3D4E6410",
                "editor.active_line.background": "#3D4E6410",
                "panel.background": "#0d0d1f90",
                "title_bar.background": "#0d0d1f90",
                "title_bar.inactive_background": "#0d0d1f90",
                "status_bar.background": "#0d0d1f90",
                "drop_target.background": "#0d0d1f90",
                "elevated_surface.background": "#0d0d1f",
                "toolbar.background": "#0d0d1f90",
                "tab_bar.background": "#0d0d1f90",
                "tab.inactive_background": "#0d0d1f90",
                "tab.active_background": "#3D4E6430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0d1f",
                "scrollbar.thumb.background": "#3D4E64",
                "editor.gutter.background": "#0d0d1f90",
                "terminal.background": "#0d0d1f10",
                "terminal.foreground": "#c2c2c7",
                "terminal.dim_foreground": "#c2c2c7",
                "terminal.bright_foreground": "#c2c2c7",
                "terminal.ansi.black": "#0d0d1f",
                "terminal.ansi.red": "#3D4E64",
                "terminal.ansi.green": "#43425E",
                "terminal.ansi.yellow": "#404060",
                "terminal.ansi.blue": "#424867",
                "terminal.ansi.magenta": "#45506B",
                "terminal.ansi.cyan": "#43506D",
                "terminal.ansi.white": "#c2c2c7",
                "terminal.ansi.bright_black": "#5c5c71",
                "terminal.ansi.bright_red": "#3D4E64",
                "terminal.ansi.bright_green": "#43425E",
                "terminal.ansi.bright_yellow": "#404060",
                "terminal.ansi.bright_blue": "#424867",
                "terminal.ansi.bright_magenta": "#45506B",
                "terminal.ansi.bright_cyan": "#43506D",
                "terminal.ansi.bright_white": "#c2c2c7",
                "modified": "#3D4E64",
                "syntax": {
                    "attribute": {
                        "color": "#3D4E64"
                    },
                    "boolean": {
                      "color": "#43425E"
                    },
                    "comment": {
                      "color": "#5c5c71"
                    },
                    "comment.doc": {
                      "color": "#5c5c71"
                    },
                    "constant": {
                      "color": "#43425E"
                    },
                    "function": {
                      "color": "#43506D"
                    },
                    "keyword": {
                      "color": "#424867"
                    },
                    "number": {
                      "color": "#45506B"
                    },
                    "operator": {
                      "color": "#424867"
                    },
                    "string": {
                      "color": "#3D4E64"
                    },
                    "variable": {
                      "color": "#43425E"
                    }
                },
                "players": [
                  {
                    "cursor": "#3D4E64",
                    "background": "#0d0d1f",
                    "selection": "#3D4E6430"
                  }
                ]
            }
        }
    ]
}
